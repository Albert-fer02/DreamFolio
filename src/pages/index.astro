---
import BaseLayout from '../layouts/BaseLayout.astro';
import EnhancedNavigation from '../components/EnhancedNavigation.tsx';
import EnhancedHeroSection from '../components/sections/EnhancedHero.tsx';
import FeaturedProjectsSection from '../components/sections/FeaturedProjectsSection.astro';
import TrinitySection from '../components/sections/TrinitySection.astro';
import CollaborationSection from '../components/sections/CollaborationSection.tsx';
import ContactSection from '../components/sections/ContactSection.tsx';
---

<BaseLayout
  title="DreamFolio | Dreamcoder08 - Builder de IA e infraestructura"
  description="Builder independiente enfocado en productos financieros confiables, resiliencia operativa y auditabilidad por diseno."
>
  <!-- Enhanced Navigation -->
  <EnhancedNavigation client:load />

  <!-- Hero Section -->
  <section id="hero">
    <EnhancedHeroSection client:load />
  </section>

  <!-- Trinity Section -->
  <TrinitySection />

  <!-- Projects Section -->
  <section id="projects">
    <FeaturedProjectsSection />
  </section>

  <!-- Collaboration Section -->
  <section id="collaboration">
    <CollaborationSection client:visible />
  </section>

  <!-- Contact Section -->
  <section id="contact">
    <ContactSection client:visible />
  </section>

  <!-- Footer -->
  <footer class="border-t border-white/6 py-12 bg-black/40 backdrop-blur-md">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div className="flex justify-center mb-6">
        <div className="h-px w-12 bg-primary/40" />
      </div>
      <p class="text-sm font-display font-medium text-zinc-300 tracking-wide uppercase">
        Infraestructura confiable, diseno claro.
      </p>
      <p class="mt-4 text-[11px] font-code text-zinc-500 uppercase tracking-[0.2em]">
        © 2026 DreamFolio — Diseno de infraestructura
      </p>
    </div>
  </footer>
</BaseLayout>
